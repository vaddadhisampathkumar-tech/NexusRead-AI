# ---- Session State ----
defaults = {
    "rag_chain": None,
    "vector_ind": None,
    "chat_history": [],
    "pdf_names": [],
    "total_chunks": 0,
    "total_pages": 0,
    "processing_time": 0,
    "suggested_questions": [],
    "show_sources": True,
    "web_search_enabled": False,
    "pending_question": None,
    "user_api_key": "",
    "api_key_valid": False,
    "voice_text": "",
    "share_menu_open": False
}
for key, value in defaults.items():
    if key not in st.session_state:
        st.session_state[key] = value
# ---- Share Helpers ----
def generate_pdf(chat_history):
    pdf = FPDF()
    pdf.add_page()
    pdf.set_font("Helvetica", "B", 16)
    pdf.cell(0, 10, "DocuMind AI - Chat Export", ln=True, align="C")
    pdf.set_font("Helvetica", "", 10)
    pdf.ln(4)
    for msg in chat_history:
        role = "You" if msg["role"] == "user" else "DocuMind"
        pdf.set_font("Helvetica", "B", 10)
        pdf.cell(0, 8, f"{role}:", ln=True)
        pdf.set_font("Helvetica", "", 9)
        clean = msg["content"].replace("*","").replace("","")
        pdf.multi_cell(0, 6, clean)
        pdf.ln(2)
    return bytes(pdf.output())

def get_chat_text(chat_history):
    lines = []
    for msg in chat_history:
        role = "You" if msg["role"] == "user" else "DocuMind"
        lines.append(f"{role}: {msg['content']}\n")
    return "\n".join(lines)

# ---- Header ----
st.markdown(
    '<div class="main-title">🧠 DocuMind AI</div>',
    unsafe_allow_html=True
)
st.markdown(
    '<div class="sub-title">Upload any PDF and get '
    'instant AI-powered answers</div>',
    unsafe_allow_html=True
)

# ---- Sidebar ----
with st.sidebar:
    st.markdown("### ⚙️ Settings")

    # Toggles
    st.session_state.show_sources = st.toggle(
        "📄 Show Source Pages",
        value=st.session_state.show_sources
    )
    st.session_state.web_search_enabled = st.toggle(
        "🌐 Web Search Fallback",
        value=st.session_state.web_search_enabled
    )

    st.markdown("---")

    # API Key Section
    st.markdown("### 🔑 API Key")
    env_key = os.getenv("GOOGLE_API_KEY", "")

    if env_key and env_key.startswith("AIza"):
        st.success("✅ System API key active")
    else:
        st.markdown("""
        <div class="api-card">
        ⚠️ No system API key found.<br>
        Enter your own Gemini API key below.
        </div>
        """, unsafe_allow_html=True)

    user_key_input = st.text_input(
        "Your Gemini API Key (optional)",
        type="password",
        placeholder="AIza...",
        help="Get free key at aistudio.google.com"
    )

    if user_key_input:
        st.session_state.user_api_key = user_key_input
        st.success("✅ Your API key will be used")

    if st.button("🔗 Get Free API Key"):
        st.markdown(
            "[Click here](https://aistudio.google.com/apikey)",
            unsafe_allow_html=True
        )

    st.markdown("---")

    # Upload PDF
    st.markdown("### 📂 Upload PDF")
    uploaded_files = st.file_uploader(
        "Choose PDF files",
        type=["pdf"],
        accept_multiple_files=True
    )

    if uploaded_files:
        new_names = [f.name for f in uploaded_files]
        if new_names != st.session_state.pdf_names:

            active_key = get_api_key(
                st.session_state.user_api_key
            )

            if not active_key:
                st.error(
                    "❌ No API key found! Please enter "
                    "your Gemini API key above."
                )
            else:
                progress = st.progress(0)
                status = st.empty()

                status.markdown("📖 Reading PDFs...")
                progress.progress(20)

                tmp_paths = []
                for f in uploaded_files:
                    with tempfile.NamedTemporaryFile(
                        delete=False, suffix=".pdf"
                    ) as tmp:
                        tmp.write(f.read())
                        tmp_paths.append(tmp.name)

                status.markdown("🔪 Splitting chunks...")
                progress.progress(40)

                try:
                    start_time = time.time()
                    status.markdown(
                        "🧠 Creating embeddings..."
                    )
                    progress.progress(60)

                    rag_chain, vector_ind, chunks, meta = \
                        build_rag_chain(
                            tmp_paths, active_key
                        )

                    status.markdown(
                        "🔗 Building RAG chain..."
                    )
                    progress.progress(80)

                    end_time = time.time()

                    st.session_state.rag_chain = rag_chain
                    st.session_state.vector_ind = vector_ind
                    st.session_state.pdf_names = new_names
                    st.session_state.total_chunks = chunks
                    st.session_state.total_pages = sum(
                        m["pages"] for m in meta
                    )
                    st.session_state.processing_time = round(
                        end_time - start_time, 1
                    )
                    st.session_state.chat_history = []

                    status.markdown(
                        "💡 Generating suggestions..."
                    )
                    progress.progress(90)

                    from langchain_community.document_loaders\
                        import PyPDFLoader
                    first_loader = PyPDFLoader(tmp_paths[0])
                    first_docs = first_loader.load()
                    pdf_text = " ".join(
                        [d.page_content for d in first_docs]
                    )
                    st.session_state.suggested_questions =\
                        get_suggested_questions(
                            pdf_text, active_key
                        )

                    progress.progress(100)
                    status.markdown("✅ Ready!")
                    time.sleep(1)
                    status.empty()
                    progress.empty()

                except Exception as e:
                    err = str(e)
                    if "429" in err or "QUOTA" in err.upper():
                        st.error(
                            "⚠️ API quota exceeded!\n\n"
                            "👉 Enter your own API key above\n"
                            "👉 Or get free key at "
                            "aistudio.google.com/apikey"
                        )
                    else:
                        st.error(f"❌ Error: {e}")
                finally:
                    for path in tmp_paths:
                        os.unlink(path)

    # PDF Stats
    if st.session_state.pdf_names:
        st.markdown("---")
        st.markdown("### 📊 PDF Stats")
        col1, col2 = st.columns(2)
        with col1:
            st.markdown(f"""
            <div class="stats-card">
                <b>{st.session_state.total_pages}</b><br>
                <small>Pages</small>
            </div>""", unsafe_allow_html=True)
        with col2:
            st.markdown(f"""
            <div class="stats-card">
                <b>{st.session_state.total_chunks}</b><br>
                <small>Chunks</small>
            </div>""", unsafe_allow_html=True)

        st.markdown(f"""
        <div class="stats-card" style="margin-top:8px">
            <b>{st.session_state.processing_time}s</b>
            Processing Time
        </div>""", unsafe_allow_html=True)

        st.markdown("---")

        if st.session_state.chat_history:
            chat_text = "\n\n".join([
                f"{m['role'].upper()}: {m['content']}"
                for m in st.session_state.chat_history
            ])
            st.download_button(
                label="💾 Download Chat",
                data=chat_text,
                file_name="documind_chat.txt",
                mime="text/plain"
            )

        if st.button("🗑️ Clear Chat"):
            st.session_state.chat_history = []
            st.rerun()

# ---- Main Area ----
if not st.session_state.rag_chain:
    st.markdown("""
    <div class="welcome-card">
        <h2>👋 Welcome to DocuMind AI!</h2>
        <p style="color:#69f0ae; font-size:1.1rem;">
        Your intelligent PDF assistant powered by 
        Google Gemini AI</p>
        <br>
        <p>📤 Upload a PDF from the sidebar</p>
        <p>🎤 Ask questions by voice or typing</p>
        <p>📄 Get answers with exact page citations</p>
        <p>🌐 Web search when PDF has no answer</p>
        <p>🔑 Use your own API key — no quota issues</p>
        <p>⬇️ Download your conversation history</p>
        <br>
        <p style="color:#00c853; font-size:0.9rem;">
        Powered by LangChain + Google Gemini AI</p>
    </div>
    """, unsafe_allow_html=True)

else:
    # Suggested Questions
    if st.session_state.suggested_questions and \
            not st.session_state.chat_history:
        st.markdown("### 💡 Suggested Questions")
        cols = st.columns(2)
        for i, question in enumerate(
            st.session_state.suggested_questions
        ):
            with cols[i % 2]:
                if st.button(question, key=f"sq_{i}"):
                    st.session_state.pending_question = \
                        question
                    st.rerun()
        st.markdown("---")

    # Chat History
    for msg in st.session_state.chat_history:
        if msg["role"] == "user":
            icon = "🎤" if msg.get("voice") else "👤"
            st.markdown(f"""
            <div class="user-bubble">
                {icon} <b>You:</b> {msg["content"]}
            </div>""", unsafe_allow_html=True)
        else:
            st.markdown(f"""
            <div class="ai-bubble">
                🧠 <b>DocuMind:</b><br>{msg["content"]}
            </div>""", unsafe_allow_html=True)
            if msg.get("web_search"):
                st.markdown(
                    "🌐 *Answer from web search*"
                )
            if "sources" in msg and \
                    st.session_state.show_sources:
                for src in msg["sources"]:
                    st.markdown(
                        f'<span class="source-badge">'
                        f'{src}</span>',
                        unsafe_allow_html=True
                    )

    # Handle pending question
    if st.session_state.pending_question:
        user_input = st.session_state.pending_question
        st.session_state.pending_question = None
        is_voice = False
    else:
        user_input = None
        is_voice = False

    # ---- Input Box ----
    typed_input = st.chat_input(
        "Ask something about your PDF..."
    )
    if typed_input:
        user_input = typed_input
        is_voice = False

    # ---- Toolbar ----
    st.markdown("---")
    (col_mic, col_web, col_src,
     col_clr, col_shr, col_space, col_send) = st.columns(
        [1, 1, 1, 1, 1, 4, 2]
    )

    # 🎙️ Voice
    with col_mic:
        mic_class = (
            "toolbar-btn-active"
            if st.session_state.get("mic_on", False)
            else "toolbar-btn"
        )
        st.markdown(
            f'<div class="{mic_class}">',
            unsafe_allow_html=True
        
        )
        st.markdown(
            f'<div class="{mic_class}">',
            unsafe_allow_html=True
        )
        voice_text = speech_to_text(
            language="en",
            start_prompt="🎙️",
            stop_prompt="⏹️",
            just_once=True,
        )
        if voice_text:
            user_input = voice_text
            is_voice = True
            st.success(f"✅ Heard: {voice_text}")
        st.markdown('</div>', unsafe_allow_html=True)

    # 🌐 Web Search Toggle
    with col_web:
        web_class = (
            "toolbar-btn-active"
            if st.session_state.web_search_enabled
            else "toolbar-btn"
        )
        st.markdown(
            f'<div class="{web_class}">',
            unsafe_allow_html=True
        )
        if st.button("🌐", help="Toggle Web Search",
                     key="web_toggle"):
            st.session_state.web_search_enabled = \
                not st.session_state.web_search_enabled
            st.rerun()
        st.markdown('</div>', unsafe_allow_html=True)

    # 📄 Sources Toggle
    with col_src:
        src_class = (
            "toolbar-btn-active"
            if st.session_state.show_sources
            else "toolbar-btn"
        )
        st.markdown(
            f'<div class="{src_class}">',
            unsafe_allow_html=True
        )
        if st.button("📄", help="Toggle Source Pages",
                     key="src_toggle"):
            st.session_state.show_sources = \
                not st.session_state.show_sources
            st.rerun()
        st.markdown('</div>', unsafe_allow_html=True)

    # 🗑️ Clear Chat
    with col_clr:
        st.markdown(
            '<div class="toolbar-btn">',
            unsafe_allow_html=True
        )
        if st.button("🗑️", help="Clear Chat",
                     key="clr_btn"):
            st.session_state.chat_history = []
            st.rerun()
        st.markdown('</div>', unsafe_allow_html=True)

    # 📤 Share Menu
    with col_shr:
        st.markdown(
            '<div class="toolbar-btn">',
            unsafe_allow_html=True
        )
        if st.button("📤", help="Share Chat",
                     key="shr_btn"):
            st.session_state.share_menu_open = \
                not st.session_state.share_menu_open
            st.rerun()
        st.markdown('</div>', unsafe_allow_html=True)

    # Share Menu Options
    if st.session_state.share_menu_open and \
            st.session_state.chat_history:
        st.markdown(
            '<div class="share-menu">',
            unsafe_allow_html=True
        )
        s1, s2, s3 = st.columns(3)

        with s1:
            chat_text = get_chat_text(
                st.session_state.chat_history
            )
            st.download_button(
                "📋 Copy Text",
                data=chat_text,
                file_name="documind_chat.txt",
                mime="text/plain",
                key="share_txt"
            )
        with s2:
            pdf_bytes = generate_pdf(
                st.session_state.chat_history
            )
            st.download_button(
                "📑 Download PDF",
                data=pdf_bytes,
                file_name="documind_chat.pdf",
                mime="application/pdf",
                key="share_pdf"
            )
        with s3:
            chat_text = get_chat_text(
                st.session_state.chat_history
            )
            b64 = base64.b64encode(
                chat_text.encode()
            ).decode()
            st.markdown(
                f'<a href="data:text/plain;'
                f'base64,{b64}" download='
                f'"documind_chat.txt">'
                f'🔗 Share Link</a>',
                unsafe_allow_html=True
            )
        st.markdown('</div>', unsafe_allow_html=True)
    voice_text = speech_to_text(
        language="en",
        start_prompt="🎙️",
        stop_prompt="⏹️",
        just_once=True,
    )
    if voice_text:
        user_input = voice_text
        is_voice = True
        st.success(f"✅ Heard: {voice_text}")
    st.markdown('</div>', unsafe_allow_html=True)

    # Process Question
    if user_input:
        active_key = get_api_key(
            st.session_state.user_api_key
        )

        st.session_state.chat_history.append({
            "role": "user",
            "content": user_input,
            "voice": is_voice
        })

        with st.spinner("🧠 DocuMind is thinking..."):
            try:
                response = st.session_state.rag_chain\
                    .invoke(user_input)

                is_web = False
                sources = []

                if "couldn't find this" in response.lower()\
                        and st.session_state\
                        .web_search_enabled:
                    with st.spinner(
                        "🌐 Searching the web..."
                    ):
                        response = web_search(
                            user_input, active_key
                        )
                        is_web = True
                else:
                    if st.session_state.show_sources:
                        sources = get_sources(
                            st.session_state.vector_ind,
                            user_input
                        )

                # Animated typing effect
                answer_placeholder = st.empty()
                displayed = ""
                for char in response:
                    displayed += char
                    answer_placeholder.markdown(
                        f'<div class="ai-bubble">'
                        f'🧠 <b>DocuMind:</b>'
                        f'<br>{displayed}▌</div>',
                        unsafe_allow_html=True
                    )
                    time.sleep(0.008)
                answer_placeholder.empty()

                st.session_state.chat_history.append({
                    "role": "assistant",
                    "content": response,
                    "sources": sources,
                    "web_search": is_web
                })

            except Exception as e:
                err = str(e)
                if "429" in err or \
                        "QUOTA" in err.upper():
                    quota_msg = (
                        "⚠️ **API quota exceeded!**\n\n"
                        "**To continue:**\n"
                        "1. Enter your own API key "
                        "in the sidebar\n"
                        "2. Get free key at: "
                        "https://aistudio.google.com"
                        "/apikey\n"
                        "3. Or wait 24 hours for "
                        "quota reset"
                    )
                    st.session_state.chat_history.append({
                        "role": "assistant",
                        "content": quota_msg,
                        "sources": [],
                        "web_search": False
                    })
                else:
                    st.session_state.chat_history.append({
                        "role": "assistant",
                        "content": f"❌ Error: {err}",
                        "sources": [],
                        "web_search": False
                    })
        st.rerun()
